---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
import { profile } from "../data/profile";
---

<BaseLayout title="Resume" sideBarActiveItemID="cv">
  <div class="mb-5">
    <div class="text-4xl w-full font-black">Professional Profile</div>
  </div>

  <div class="mb-10 rounded-[2rem] border border-base-300 bg-base-200 p-8 text-justify leading-8">
    {profile.summary}
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Core Strengths</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2 text-lg">
    {profile.expertiseAreas.map((skill) => <li>{skill}</li>)}
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Experience</div>
  </div>

  <div class="time-line-container mb-10">
    {
      profile.experiences.map((item) => (
        <TimeLineElement title={item.title} subtitle={item.org}>
          {item.detail}
        </TimeLineElement>
      ))
    }
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    {
      profile.education.map((item) => (
        <TimeLineElement title={item.title} subtitle="Education and foundation">
          {item.detail}
        </TimeLineElement>
      ))
    }
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Current Learning and Certifications</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2 text-lg">
    {profile.learning.map((item) => <li>{item}</li>)}
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Technical Stack</div>
  </div>

  <ul class="list-disc md:columns-4 columns-2 mx-6">
    {profile.technologies.map((item) => <li>{item}</li>)}
  </ul>
</BaseLayout>
