---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { profile } from "../data/profile";
---

<BaseLayout title="Expertise" sideBarActiveItemID="services">
  <div class="rounded-[2rem] border border-base-300 bg-gradient-to-br from-base-200 via-base-100 to-base-200 p-8">
    <div class="text-4xl font-black">Expertise</div>
    <p class="mt-4 max-w-3xl text-lg leading-8">
      I bring a hybrid profile: advanced analytics, machine learning, research thinking, and system-level delivery. That
      combination helps teams move from ambiguous data problems to practical outcomes.
    </p>
  </div>

  <div class="mt-8">
    {
      profile.services.map((service, index) => (
        <>
          <HorizontalCard
            title={service.title}
            img="/itemPreview.webp"
            desc={service.desc}
            badge="Focus Area"
            url="#"
          />
          {index < profile.services.length - 1 && <div class="divider my-0"></div>}
        </>
      ))
    }
  </div>
</BaseLayout>
