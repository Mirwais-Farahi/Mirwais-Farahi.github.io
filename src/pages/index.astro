---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { profile } from "../data/profile";
---

<BaseLayout sideBarActiveItemID="home">
  <section class="mt-4 rounded-[2rem] border border-base-300 bg-gradient-to-br from-base-200 via-base-100 to-base-200 p-8 shadow-sm">
    <div class="grid gap-8 lg:grid-cols-[1.6fr,1fr] lg:items-start">
      <div>
        <div class="badge badge-outline mb-4">Advanced Data Scientist Profile</div>
        <h1 class="text-4xl md:text-6xl font-black leading-tight">{profile.name}</h1>
        <p class="mt-3 text-2xl md:text-3xl font-semibold text-primary">{profile.headline}</p>
        <p class="mt-3 text-lg opacity-80 max-w-3xl">{profile.subheadline}</p>
        <p class="mt-6 text-base md:text-lg leading-8 max-w-3xl">{profile.summary}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="btn btn-primary" href="/cv">View full profile</a>
          <a class="btn btn-outline" href={profile.github} target="_blank">GitHub</a>
          <a class="btn btn-outline" href={`mailto:${profile.email}`}>Email</a>
        </div>
      </div>
      <div class="grid gap-4">
        {
          profile.introStats.map((stat) => (
            <div class="rounded-2xl border border-base-300 bg-base-100 p-5 shadow-sm">
              <div class="text-sm uppercase tracking-[0.2em] opacity-60">{stat.label}</div>
              <div class="mt-2 text-xl font-bold leading-snug">{stat.value}</div>
            </div>
          ))
        }
        <div class="rounded-2xl border border-primary/20 bg-primary/10 p-5">
          <div class="text-sm uppercase tracking-[0.2em] text-primary">Based in</div>
          <div class="mt-2 text-xl font-bold">{profile.location}</div>
        </div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <div class="text-3xl font-bold">What I bring</div>
    <div class="mt-5 grid gap-4 md:grid-cols-3">
      {
        profile.highlights.map((item) => (
          <div class="rounded-2xl border border-base-300 bg-base-100 p-5 leading-7 shadow-sm">
            {item}
          </div>
        ))
      }
    </div>
  </section>

  <section class="mt-12">
    <div class="flex items-end justify-between gap-4">
      <div>
        <div class="text-3xl font-bold">Selected Projects</div>
        <p class="mt-2 opacity-75">A focused view of applied analytics, research, and systems delivery work.</p>
      </div>
      <a href="/projects" class="link link-hover font-semibold">See all projects</a>
    </div>
    <div class="mt-4"></div>
    {
      profile.projects.slice(0, 3).map((project, index) => (
        <>
          <HorizontalCard
            title={project.title}
            img={project.img}
            desc={project.desc}
            url="/projects"
            target="_self"
            badge={project.badge}
          />
          {index < 2 && <div class="divider my-0"></div>}
        </>
      ))
    }
  </section>

  <section class="mt-12">
    <div class="text-3xl font-bold">Core Stack</div>
    <div class="mt-5 flex flex-wrap gap-3">
      {
        profile.technologies.map((skill) => (
          <div class="badge badge-lg badge-outline px-4 py-4">{skill}</div>
        ))
      }
    </div>
  </section>

  <section class="mt-12 rounded-[2rem] border border-base-300 bg-base-200 p-8">
    <div class="text-3xl font-bold">Open to impactful data work</div>
    <p class="mt-3 max-w-3xl text-lg leading-8">
      I work at the intersection of data science, system analysis, and research-led problem solving. If you need help with
      machine learning, analytical design, data quality, or delivery of complex data products, let&apos;s talk.
    </p>
    <div class="mt-6">
      <a class="btn btn-primary" href={`mailto:${profile.email}`}>Contact Mirwais</a>
    </div>
  </section>
</BaseLayout>
