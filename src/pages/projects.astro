---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { profile } from "../data/profile";
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <div class="rounded-[2rem] border border-base-300 bg-base-200 p-8">
    <div class="text-4xl font-black">Selected Work</div>
    <p class="mt-4 max-w-3xl text-lg leading-8">
      This project view highlights the kind of work I want the profile to communicate: applied machine learning, data
      quality leadership, research depth, and systems delivery in real operating environments.
    </p>
  </div>

  <div class="mt-8">
    {
      profile.projects.map((project, index) => (
        <>
          <HorizontalCard
            title={project.title}
            img={project.img}
            desc={project.desc}
            url="#"
            badge={project.badge}
          />
          {index < profile.projects.length - 1 && <div class="divider my-0"></div>}
        </>
      ))
    }
  </div>
</BaseLayout>
